{
  "name": "@ianrelecker/m365mcp",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Local MCP server for Microsoft 365 delegated Graph access.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ianrelecker/m365mcp.git"
  },
  "homepage": "https://github.com/ianrelecker/m365mcp#readme",
  "bugs": {
    "url": "https://github.com/ianrelecker/m365mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "m365mcp": "./bin/m365mcp.js"
  },
  "files": [
