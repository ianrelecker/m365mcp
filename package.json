{
  "name": "claude-m365-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local Claude Desktop MCP server for a single Microsoft 365 user with delegated Microsoft Graph access.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "5.0.5",
    "@types/node": "22.15.30",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
