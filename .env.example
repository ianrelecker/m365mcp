PORT=8787
# Optional. Defaults to http://localhost:${PORT}
LOCAL_BASE_URL=http://localhost:8787

# Microsoft Entra
# Add the delegated Graph scopes listed in README.md. If scopes change after
# you have connected once, reconnect Microsoft so the token includes them.
MICROSOFT_TENANT_ID=your-tenant-id
MICROSOFT_CLIENT_ID=your-client-id

# Required. Use the client secret Value from Azure, not the Secret ID.
MICROSOFT_CLIENT_SECRET=your-client-secret-value

# 32-byte key encoded as base64. Generate one with:
# python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
TOKEN_ENCRYPTION_KEY=replace-me

# SECURITY: After copying this file to .env, restrict its permissions:
#   chmod 600 .env
# On Windows, restrict via Properties > Security > Advanced so only your user
# account has access. This file contains plaintext secrets; world-readable
# permissions defeat the token encryption.

# Optional comma-separated list of shared/delegated mailbox addresses to hint in docs/UI.
KNOWN_MAILBOXES=

# Optional local JSONL audit log for MCP tool calls. The log records metadata only,
# never tokens, secrets, email bodies, attachment content, or raw Graph payloads.
M365_AUDIT_LOG_ENABLED=true
M365_AUDIT_LOG_FILE=.audit/m365-mcp-audit.jsonl
