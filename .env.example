PORT=8787
# Optional. Defaults to http://localhost:${PORT}
LOCAL_BASE_URL=http://localhost:8787

# Microsoft Entra
MICROSOFT_TENANT_ID=your-tenant-id
MICROSOFT_CLIENT_ID=your-client-id

# Optional. Only needed if you intentionally keep a confidential-client/web
# app registration. The recommended local Desktop setup uses PKCE and leaves
# this blank.
MICROSOFT_CLIENT_SECRET=

# 32-byte key encoded as base64. Generate one with:
# python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
TOKEN_ENCRYPTION_KEY=replace-me

# Optional comma-separated list of shared/delegated mailbox addresses to hint in docs/UI.
KNOWN_MAILBOXES=
